{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "yaml.format.enable": false,
  "javascript.suggestionActions.enabled": false,
  "typescript.suggestionActions.enabled": false,
  "typescript.tsdk": "node_modules/typescript/lib",
  "files.exclude": {
    "**/.git": true,
    "**/target": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/dist": true,
    "**/Thumbs.db": true,
    "**/node_modules": true,
    "**/.nx": true
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "[rust]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "search.useIgnoreFiles": false,
  "cSpell.words": ["postcss", "pubstudio"],
  "rust-analyzer.linkedProjects": ["./backend/Cargo.toml"],
  "rust-analyzer.numThreads": 6,
  "rust-analyzer.cachePriming.numThreads": 6,
  "rust-analyzer.check.extraArgs": ["-j", "6"],
  "rust-analyzer.cargo.extraEnv": { "CARGO_BUILD_JOBS": "6" },
  "rust-analyzer.lru.capacity": 128,
  "[sql]": {
    "editor.tabSize": 4
  },
  "rust-analyzer.showUnlinkedFileNotification": false
}
