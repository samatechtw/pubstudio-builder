{
  "name": "pubstudio-builder",
  "version": "1.0.0",
  "description": "Page editor, renderer, and backend that powers https://pubstud.io",
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "type": "module",
  "scripts": {
    "format": "nx format:write",
    "format:check": "nx format:check",
    "lint": "nx workspace-lint && nx lint",
    "lint:style": "./node_modules/stylelint/bin/stylelint.js \"**/src/**/*.{css,vue}\"",
    "build:web-site": "npx nx build web-site --skip-nx-cache && cp ./dist/apps/web-site/index.html ./backend/",
    "build:feature-external": "cd libs/frontend/feature-external && npm run build",
    "build:util-external": "cd libs/frontend/util-external && npm run build",
    "publish": "cd dist/libs/feature-external/ && npm publish --access=public",
    "dev:build-aarch": "cd backend && CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER=aarch64-unknown-linux-gnu-gcc cargo build --target aarch64-unknown-linux-gnu",
    "dev:run-aarch": "cd backend && CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER=aarch64-unknown-linux-gnu-gcc cargo run --target aarch64-unknown-linux-gnu",
    "dev:build": "cd backend && cargo build",
    "dev:build:docker": "./tools/scripts/dev-build-docker.sh",
    "dev:run": "cd backend && cargo run",
    "dev:watch": "cd backend && cargo watch --why -x run",
    "dev:watch-aarch": "cd backend && CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER=aarch64-unknown-linux-gnu-gcc cargo watch --why -- bash -c \"(cargo build --target aarch64-unknown-linux-gnu)\"",
    "prod:build": "cd backend && CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER=aarch64-unknown-linux-gnu-gcc cargo build --release --target aarch64-unknown-linux-gnu",
    "ci:build": "cd backend && cargo build --release",
    "prune": "tools/scripts/prune-all.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samatechtw/pubstudio-builder.git"
  },
  "keywords": [],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/samatechtw/pubstudio-builder/issues"
  },
  "homepage": "https://github.com/samatechtw/pubstudio-builder#README",
  "author": "SamaTech",
  "dependencies": {
    "@floating-ui/vue": "^1.1.9",
    "@samatech/vue-components": "1.4.0",
    "@samatech/vue-store": "^0.7.1",
    "@sampullman/fetch-api": "^0.12.1",
    "date-fns": "^4.1.0",
    "highlight.js": "^11.11.1",
    "jwt-decode": "^4.0.0",
    "petite-vue-i18n": "^11.1.12",
    "prosemirror-gapcursor": "^1.4.0",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.10.4",
    "prosemirror-view": "^1.41.3",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.0",
    "@jest/globals": "^29.7.0",
    "@laynezh/vite-plugin-lib-assets": "^1.1.0",
    "@nx/eslint": "20.5.0",
    "@nx/eslint-plugin": "20.5.0",
    "@nx/jest": "20.5.0",
    "@nx/js": "20.5.0",
    "@nx/workspace": "20.5.0",
    "@samatech/image-api-types": "^0.0.2",
    "@samatech/postcss-basics": "^0.7.4",
    "@samatech/vue-color-picker": "^1.2.0",
    "@types/convict": "^6.1.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@videojs/themes": "^1.0.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-typescript": "^13.0.0",
    "commitlint": "^20.1.0",
    "convict": "^6.2.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-vue": "^9.32.0",
    "esno": "^4.8.0",
    "jest": "^29.7.0",
    "jest-localstorage-mock": "^2.4.26",
    "jsonwebtoken": "^9.0.2",
    "lightningcss": "^1.30.2",
    "nx": "20.5.0",
    "nx-vue3-vite": "0.30.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "supertest": "^7.1.4",
    "terser": "^5.44.0",
    "ts-jest": "^29.4.5",
    "ts-jest-mock-import-meta": "^1.3.1",
    "typescript": "^5.9.3",
    "vite": "7.1.12",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-singlefile": "^2.3.0",
    "vue-eslint-parser": "^9.4.3"
  }
}
