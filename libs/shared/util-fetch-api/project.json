{
  "name": "shared-util-fetch-api",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/util-fetch-api/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/shared/util-fetch-api/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --passWithNoTests",
        "cwd": "libs/shared/util-fetch-api"
      },
      "configurations": {
        "ci": {
          "command": "vitest run --passWithNoTests --coverage"
        }
      }
    }
  },
  "tags": ["scope:shared", "type:util"]
}
